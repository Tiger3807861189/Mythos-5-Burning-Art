{
  "description": "Mythos 5 Burning Art routing, approval, and completion guards.",
  "hooks": {
    "SessionStart": [{"matcher": "startup|resume|clear|compact", "hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "SessionStart"], "timeout": 10, "statusMessage": "Loading the Mythos lifecycle"}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "UserPromptSubmit"], "timeout": 10, "statusMessage": "Routing the request through Mythos"}]}],
    "PreToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "PreToolUse"], "timeout": 10, "statusMessage": "Checking the Mythos approval gate"}]}],
    "PermissionRequest": [{"matcher": "*", "hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "PermissionRequest"], "timeout": 10, "statusMessage": "Checking whether this permission is in the approved plan"}]}],
    "SubagentStart": [{"matcher": ".*mythos-plan-critic$|.*mythos-verifier$", "hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "SubagentStart"], "timeout": 10, "statusMessage": "Auditing the independent review context"}]}],
    "SubagentStop": [{"matcher": ".*mythos-plan-critic$|.*mythos-verifier$", "hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "SubagentStop"], "timeout": 20, "statusMessage": "Recording the independent review"}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "${user_config.python_executable}", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mythos_hook.py", "--host", "claude", "--event", "Stop"], "timeout": 20, "statusMessage": "Checking the Mythos completion ledger"}]}]
  }
}

