{
  "description": "Mythos 5 Burning Art routing, approval, and completion guards.",
  "hooks": {
    "SessionStart": [{"matcher": "startup|resume|clear|compact", "hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event SessionStart", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event SessionStart", "timeout": 10, "statusMessage": "Loading the Mythos lifecycle"}]}],
    "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event UserPromptSubmit", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event UserPromptSubmit", "timeout": 10, "statusMessage": "Routing the request through Mythos"}]}],
    "PreToolUse": [{"matcher": ".*", "hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event PreToolUse", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event PreToolUse", "timeout": 10, "statusMessage": "Checking the Mythos approval gate"}]}],
    "PermissionRequest": [{"matcher": ".*", "hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event PermissionRequest", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event PermissionRequest", "timeout": 10, "statusMessage": "Checking whether this permission is in the approved plan"}]}],
    "SubagentStart": [{"matcher": ".*mythos-plan-critic$|.*mythos-verifier$", "hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event SubagentStart", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event SubagentStart", "timeout": 10, "statusMessage": "Auditing the independent review context"}]}],
    "SubagentStop": [{"matcher": ".*mythos-plan-critic$|.*mythos-verifier$", "hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event SubagentStop", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event SubagentStop", "timeout": 20, "statusMessage": "Recording the independent review"}]}],
    "Stop": [{"hooks": [{"type": "command", "command": "python3 \"$PLUGIN_ROOT/scripts/mythos_hook.py\" --host codex --event Stop", "commandWindows": "py -3 \"$env:PLUGIN_ROOT\\scripts\\mythos_hook.py\" --host codex --event Stop", "timeout": 20, "statusMessage": "Checking the Mythos completion ledger"}]}]
  }
}
