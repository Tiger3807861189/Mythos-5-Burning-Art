{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/sealed-verification-packet.schema.json",
  "title": "Hook-Owned Sealed Verification Packet",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "approval_bundle_hash",
    "implementation_notes",
    "increment_evidence",
    "acceptance_evidence",
    "reconciliation",
    "task_profile",
    "original_request",
    "goal",
    "intake",
    "territory_discovery",
    "unknowns",
    "options",
    "applicable_instructions",
    "approved_plan",
    "approved_mutation_scope",
    "acceptance_criteria",
    "base_fingerprint",
    "final_fingerprint",
    "base_manifest_hash",
    "final_manifest_hash",
    "changed_inventory",
    "content_delta",
    "context_manifest"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "$ref": "#/$defs/nonempty_string"
    },
    "approval_bundle_hash": {
      "$ref": "#/$defs/digest"
    },
    "implementation_notes": {
      "type": "object",
      "minProperties": 1
    },
    "increment_evidence": {
      "$ref": "#/$defs/increment_evidence"
    },
    "acceptance_evidence": {
      "$ref": "#/$defs/acceptance_evidence"
    },
    "reconciliation": {
      "$ref": "#/$defs/hook_reconciliation"
    },
    "task_profile": {
      "enum": [
        "build",
        "debug",
        "repair",
        "plan_only"
      ]
    },
    "original_request": {
      "$ref": "#/$defs/request"
    },
    "goal": {
      "$ref": "#/$defs/nonempty_string"
    },
    "intake": {
      "$ref": "#/$defs/intake"
    },
    "territory_discovery": {
      "$ref": "#/$defs/territory"
    },
    "unknowns": {
      "$ref": "#/$defs/unknowns"
    },
    "options": {
      "$ref": "#/$defs/options"
    },
    "applicable_instructions": {
      "type": "object",
      "required": [
        "planner_declared",
        "hook_observed"
      ],
      "properties": {
        "planner_declared": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "hook_observed": {
          "items": {
            "$ref": "#/$defs/instruction_entry"
          },
          "type": "array"
        }
      },
      "additionalProperties": false
    },
    "approved_plan": {
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plan_step"
      },
      "type": "array"
    },
    "approved_mutation_scope": {
      "$ref": "#/$defs/scope"
    },
    "acceptance_criteria": {
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/criterion"
      },
      "type": "array"
    },
    "base_fingerprint": {
      "$ref": "#/$defs/digest"
    },
    "final_fingerprint": {
      "$ref": "#/$defs/digest"
    },
    "base_manifest_hash": {
      "$ref": "#/$defs/digest"
    },
    "final_manifest_hash": {
      "$ref": "#/$defs/digest"
    },
    "changed_inventory": {
      "items": {
        "$ref": "#/$defs/changed_entry"
      },
      "type": "array"
    },
    "content_delta": {
      "items": {
        "$ref": "#/$defs/content_delta_entry"
      },
      "type": "array"
    },
    "context_manifest": {
      "$ref": "#/$defs/context_manifest"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonempty_string"
      }
    },
    "nonempty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonempty_string"
      }
    },
    "portable_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*:).+$"
    },
    "intake": {
      "type": "object",
      "required": [
        "outcome",
        "scope",
        "constraints",
        "non_goals",
        "authorization"
      ],
      "properties": {
        "outcome": {
          "$ref": "#/$defs/nonempty_string"
        },
        "scope": {
          "$ref": "#/$defs/nonempty_string"
        },
        "constraints": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "non_goals": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "authorization": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "territory": {
      "type": "object",
      "required": [
        "repository_map",
        "instructions",
        "conventions",
        "baseline"
      ],
      "properties": {
        "repository_map": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "instructions": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "conventions": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "baseline": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "unknowns": {
      "type": "object",
      "required": [
        "known_knowns",
        "known_unknowns",
        "unknown_knowns",
        "unknown_unknowns",
        "blindspot_pass"
      ],
      "properties": {
        "known_knowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "known_unknowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "unknown_knowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "unknown_unknowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "blindspot_pass": {
          "$ref": "#/$defs/nonempty_string_array"
        }
      },
      "additionalProperties": false
    },
    "options": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status",
            "disposition"
          ],
          "properties": {
            "status": {
              "const": "PASS"
            },
            "disposition": {
              "$ref": "#/$defs/nonempty_string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "status",
            "disposition",
            "code",
            "reason",
            "evidence"
          ],
          "properties": {
            "status": {
              "const": "NOT_APPLICABLE"
            },
            "disposition": {
              "$ref": "#/$defs/nonempty_string"
            },
            "code": {
              "enum": [
                "single_mechanical_outcome",
                "no_safe_executable_prototype"
              ]
            },
            "reason": {
              "$ref": "#/$defs/nonempty_string"
            },
            "evidence": {
              "type": "object",
              "minProperties": 2
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "criterion": {
      "type": "object",
      "required": [
        "id",
        "pass_condition",
        "verification"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "pass_condition": {
          "$ref": "#/$defs/nonempty_string"
        },
        "verification": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "plan_step": {
      "type": "object",
      "required": [
        "id",
        "surfaces",
        "action",
        "verification",
        "rollback"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "surfaces": {
          "$ref": "#/$defs/string_array"
        },
        "action": {
          "$ref": "#/$defs/nonempty_string"
        },
        "verification": {
          "$ref": "#/$defs/nonempty_string"
        },
        "rollback": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "paths",
        "commands",
        "external_effects"
      ],
      "properties": {
        "paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/portable_relative_path"
          }
        },
        "commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonempty_string"
          }
        },
        "external_effects": {
          "type": "array",
          "maxItems": 0
        }
      },
      "additionalProperties": false
    },
    "increment_evidence": {
      "$comment": "The runtime requires one PASS entry per approved step and an empty array for plan_only.",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "result"
        ],
        "properties": {
          "step": {
            "$ref": "#/$defs/nonempty_string"
          },
          "result": {
            "const": "PASS"
          },
          "evidence": {
            "$ref": "#/$defs/nonempty_string"
          },
          "observation": {
            "$ref": "#/$defs/nonempty_string"
          }
        },
        "anyOf": [
          {
            "required": [
              "evidence"
            ]
          },
          {
            "required": [
              "observation"
            ]
          }
        ],
        "additionalProperties": false
      }
    },
    "acceptance_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "evidence",
          "result"
        ],
        "properties": {
          "criterion": {
            "$ref": "#/$defs/nonempty_string"
          },
          "evidence": {
            "$ref": "#/$defs/nonempty_string"
          },
          "result": {
            "const": "PASS"
          }
        },
        "additionalProperties": false
      }
    },
    "deviation": {
      "type": "object",
      "required": [
        "subject_type",
        "subject_id",
        "classification",
        "evidence"
      ],
      "properties": {
        "subject_type": {
          "enum": [
            "PLAN_STEP",
            "ACCEPTANCE_CRITERION",
            "PATH",
            "COMMAND"
          ]
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "enum": [
            "MATCH",
            "NECESSARY_DEVIATION",
            "BENEFICIAL_DEVIATION"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "required": [
        "text",
        "request_hash",
        "turn_id"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "request_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "instruction_entry": {
      "type": "object",
      "required": [
        "path",
        "kind",
        "sha256",
        "content"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "const": "file"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "content": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "context_manifest": {
      "type": "object",
      "required": [
        "project",
        "project_fingerprint",
        "content_manifest_hash",
        "content_entry_count",
        "task_profile",
        "original_request_hash",
        "latest_human_instruction",
        "planner_declared_instructions",
        "hook_observed_instruction_files"
      ],
      "properties": {
        "project": {
          "type": "object",
          "minProperties": 4
        },
        "project_fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "content_manifest_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "content_entry_count": {
          "type": "integer",
          "minimum": 0
        },
        "task_profile": {
          "enum": [
            "build",
            "debug",
            "repair",
            "plan_only"
          ]
        },
        "original_request_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "latest_human_instruction": {
          "$ref": "#/$defs/request"
        },
        "planner_declared_instructions": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "hook_observed_instruction_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/instruction_entry"
          }
        }
      },
      "additionalProperties": false
    },
    "hook_reconciliation": {
      "type": "object",
      "required": [
        "deviations",
        "final_scope",
        "final_fingerprint"
      ],
      "properties": {
        "deviations": {
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deviation"
          },
          "type": "array"
        },
        "final_scope": {
          "items": {
            "$ref": "#/$defs/portable_relative_path"
          },
          "type": "array"
        },
        "final_fingerprint": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "changed_entry": {
      "type": "object",
      "required": [
        "path",
        "status"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/portable_relative_path"
        },
        "status": {
          "enum": [
            "ADDED",
            "MODIFIED",
            "DELETED"
          ]
        },
        "before_kind": {
          "minLength": 1,
          "type": "string"
        },
        "before_sha256": {
          "$ref": "#/$defs/digest"
        },
        "after_kind": {
          "minLength": 1,
          "type": "string"
        },
        "after_sha256": {
          "$ref": "#/$defs/digest"
        }
      },
      "additionalProperties": false
    },
    "snapshot_entry": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "path",
            "kind",
            "sha256",
            "encoding",
            "data"
          ],
          "properties": {
            "path": {
              "$ref": "#/$defs/portable_relative_path"
            },
            "kind": {
              "enum": [
                "file",
                "symlink"
              ]
            },
            "sha256": {
              "$ref": "#/$defs/digest"
            },
            "encoding": {
              "enum": [
                "utf-8",
                "base64"
              ]
            },
            "data": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "path",
            "kind",
            "sha256"
          ],
          "properties": {
            "path": {
              "$ref": "#/$defs/portable_relative_path"
            },
            "kind": {
              "const": "unreadable"
            },
            "sha256": {
              "$ref": "#/$defs/digest"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "content_delta_entry": {
      "type": "object",
      "required": [
        "path",
        "status",
        "before",
        "after"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/portable_relative_path"
        },
        "status": {
          "enum": [
            "ADDED",
            "MODIFIED",
            "DELETED"
          ]
        },
        "before": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/snapshot_entry"
            }
          ]
        },
        "after": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/snapshot_entry"
            }
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
