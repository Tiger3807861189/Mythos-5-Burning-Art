{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/event.schema.json",
  "title": "Mythos Runtime Chained Event Record",
  "type": "object",
  "required": ["sequence", "previous_checksum", "payload", "checksum"],
  "properties": {
    "sequence": {"type": "integer", "minimum": 1},
    "previous_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "payload": {"$ref": "#/$defs/event_payload"},
    "checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "event_payload": {
      "type": "object",
      "required": ["operation"],
      "properties": {
        "operation": {"enum": ["initialize", "transition", "set_task_profile", "record_evidence", "attempt", "set_terminal", "resume", "batch", "approval_created", "approval_invalidated"]},
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["operation"],
            "properties": {"operation": {"enum": ["transition", "record_evidence"]}},
            "additionalProperties": true
          }
        }
      },
      "if": {"properties": {"operation": {"const": "batch"}}, "required": ["operation"]},
      "then": {"required": ["events"]},
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}