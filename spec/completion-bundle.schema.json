{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/completion-bundle.schema.json",
  "title": "Mythos Completion Bundle",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "verification_packet_hash",
    "implementation_notes",
    "increment_evidence",
    "acceptance_evidence",
    "reconciliation",
    "explanation"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "$ref": "#/$defs/nonempty_string"
    },
    "verification_packet_hash": {
      "$ref": "#/$defs/digest"
    },
    "implementation_notes": {
      "type": "object",
      "minProperties": 1
    },
    "increment_evidence": {
      "$ref": "#/$defs/increment_evidence"
    },
    "acceptance_evidence": {
      "$ref": "#/$defs/acceptance_evidence"
    },
    "reconciliation": {
      "$ref": "#/$defs/submitted_reconciliation"
    },
    "explanation": {
      "$ref": "#/$defs/explanation"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "increment_evidence": {
      "$comment": "The runtime requires one PASS entry per approved step and an empty array for plan_only.",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "result"
        ],
        "properties": {
          "step": {
            "$ref": "#/$defs/nonempty_string"
          },
          "result": {
            "const": "PASS"
          },
          "evidence": {
            "$ref": "#/$defs/nonempty_string"
          },
          "observation": {
            "$ref": "#/$defs/nonempty_string"
          }
        },
        "anyOf": [
          {
            "required": [
              "evidence"
            ]
          },
          {
            "required": [
              "observation"
            ]
          }
        ],
        "additionalProperties": false
      }
    },
    "acceptance_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "evidence",
          "result"
        ],
        "properties": {
          "criterion": {
            "$ref": "#/$defs/nonempty_string"
          },
          "evidence": {
            "$ref": "#/$defs/nonempty_string"
          },
          "result": {
            "const": "PASS"
          }
        },
        "additionalProperties": false
      }
    },
    "submitted_reconciliation": {
      "$comment": "The submitter supplies only deviations. The hook derives final scope and fingerprint.",
      "type": "object",
      "required": [
        "deviations"
      ],
      "properties": {
        "deviations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deviation"
          }
        }
      },
      "additionalProperties": false
    },
    "explanation": {
      "type": "object",
      "required": [
        "change_explanation",
        "risks",
        "rollback",
        "comprehension_evidence"
      ],
      "properties": {
        "change_explanation": {
          "$ref": "#/$defs/nonempty_string"
        },
        "risks": {
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonempty_string"
          },
          "type": "array"
        },
        "rollback": {
          "$ref": "#/$defs/nonempty_string"
        },
        "comprehension_evidence": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "deviation": {
      "type": "object",
      "required": [
        "subject_type",
        "subject_id",
        "classification",
        "evidence"
      ],
      "properties": {
        "subject_type": {
          "enum": [
            "PLAN_STEP",
            "ACCEPTANCE_CRITERION",
            "PATH",
            "COMMAND"
          ]
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "enum": [
            "MATCH",
            "NECESSARY_DEVIATION",
            "BENEFICIAL_DEVIATION"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
