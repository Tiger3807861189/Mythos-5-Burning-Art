{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/attempt-packet.schema.json",
  "title": "Mythos Durable Implementation Attempt Packet",
  "type": "object",
  "required": ["schema_version", "run_id", "approval_bundle_hash", "step", "hypothesis", "action", "evidence_snapshot", "outcome", "evidence_gain"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "approval_bundle_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "step": {"type": "string", "minLength": 1},
    "hypothesis": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "evidence_snapshot": {"type": "string", "minLength": 1},
    "outcome": {"enum": ["PASS", "FAIL"]},
    "evidence_gain": {"type": "boolean"}
  },
  "allOf": [{"if": {"properties": {"outcome": {"const": "PASS"}}}, "then": {"properties": {"evidence_gain": {"const": true}}}}],
  "additionalProperties": false
}