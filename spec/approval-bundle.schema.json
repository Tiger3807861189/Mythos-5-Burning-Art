{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/approval-bundle.schema.json",
  "title": "Mythos Approval Bundle",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_profile",
    "goal",
    "intake",
    "territory_discovery",
    "unknowns",
    "options",
    "acceptance_criteria",
    "plan",
    "mutation_scope",
    "review_packet_hash",
    "critic"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "$ref": "#/$defs/nonempty_string"
    },
    "task_profile": {
      "enum": [
        "build",
        "debug",
        "repair",
        "plan_only"
      ]
    },
    "goal": {
      "$ref": "#/$defs/nonempty_string"
    },
    "intake": {
      "$ref": "#/$defs/intake"
    },
    "territory_discovery": {
      "$ref": "#/$defs/territory"
    },
    "unknowns": {
      "$ref": "#/$defs/unknowns"
    },
    "options": {
      "$ref": "#/$defs/options"
    },
    "acceptance_criteria": {
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/criterion"
      },
      "type": "array"
    },
    "plan": {
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/plan_step"
      },
      "type": "array"
    },
    "mutation_scope": {
      "$ref": "#/$defs/scope"
    },
    "replan_from": {
      "const": "UNKNOWNS_AND_BLINDSPOTS"
    },
    "review_packet_hash": {
      "$ref": "#/$defs/digest"
    },
    "critic": {
      "additionalProperties": false,
      "properties": {
        "adjudication": {
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1
          },
          "type": "array"
        }
      },
      "required": [
        "adjudication"
      ],
      "type": "object"
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/phase4_na_policy"
    },
    {
      "oneOf": [
        {
          "properties": {
            "task_profile": {
              "const": "plan_only"
            },
            "mutation_scope": {
              "properties": {
                "paths": {
                  "maxItems": 0
                },
                "commands": {
                  "maxItems": 0
                },
                "external_effects": {
                  "maxItems": 0
                }
              }
            },
            "plan": {
              "items": {
                "properties": {
                  "surfaces": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "properties": {
            "task_profile": {
              "const": "debug"
            },
            "mutation_scope": {
              "properties": {
                "external_effects": {
                  "maxItems": 0
                },
                "paths": {
                  "maxItems": 0
                }
              }
            },
            "plan": {
              "items": {
                "properties": {
                  "surfaces": {
                    "maxItems": 0
                  }
                }
              }
            }
          }
        },
        {
          "properties": {
            "task_profile": {
              "enum": [
                "build",
                "debug",
                "repair"
              ]
            },
            "mutation_scope": {
              "properties": {
                "external_effects": {
                  "maxItems": 0
                },
                "paths": {
                  "minItems": 1
                }
              }
            },
            "plan": {
              "items": {
                "properties": {
                  "surfaces": {
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      ]
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "nonempty_string": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonempty_string"
      }
    },
    "nonempty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonempty_string"
      }
    },
    "portable_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*:).+$"
    },
    "intake": {
      "type": "object",
      "required": [
        "outcome",
        "scope",
        "constraints",
        "non_goals",
        "authorization"
      ],
      "properties": {
        "outcome": {
          "$ref": "#/$defs/nonempty_string"
        },
        "scope": {
          "$ref": "#/$defs/nonempty_string"
        },
        "constraints": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "non_goals": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "authorization": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "territory": {
      "type": "object",
      "required": [
        "repository_map",
        "instructions",
        "conventions",
        "baseline"
      ],
      "properties": {
        "repository_map": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "instructions": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "conventions": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "baseline": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "unknowns": {
      "type": "object",
      "required": [
        "known_knowns",
        "known_unknowns",
        "unknown_knowns",
        "unknown_unknowns",
        "blindspot_pass"
      ],
      "properties": {
        "known_knowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "known_unknowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "unknown_knowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "unknown_unknowns": {
          "$ref": "#/$defs/nonempty_string_array"
        },
        "blindspot_pass": {
          "$ref": "#/$defs/nonempty_string_array"
        }
      },
      "additionalProperties": false
    },
    "options": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "status",
            "disposition"
          ],
          "properties": {
            "status": {
              "const": "PASS"
            },
            "disposition": {
              "$ref": "#/$defs/nonempty_string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "status",
            "disposition",
            "code",
            "reason",
            "evidence"
          ],
          "properties": {
            "status": {
              "const": "NOT_APPLICABLE"
            },
            "disposition": {
              "$ref": "#/$defs/nonempty_string"
            },
            "code": {
              "enum": [
                "single_mechanical_outcome",
                "no_safe_executable_prototype"
              ]
            },
            "reason": {
              "$ref": "#/$defs/nonempty_string"
            },
            "evidence": {
              "type": "object",
              "minProperties": 2
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "criterion": {
      "type": "object",
      "required": [
        "id",
        "pass_condition",
        "verification"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "pass_condition": {
          "$ref": "#/$defs/nonempty_string"
        },
        "verification": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "plan_step": {
      "type": "object",
      "required": [
        "id",
        "surfaces",
        "action",
        "verification",
        "rollback"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "surfaces": {
          "$ref": "#/$defs/string_array"
        },
        "action": {
          "$ref": "#/$defs/nonempty_string"
        },
        "verification": {
          "$ref": "#/$defs/nonempty_string"
        },
        "rollback": {
          "$ref": "#/$defs/nonempty_string"
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "paths",
        "commands",
        "external_effects"
      ],
      "properties": {
        "paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/portable_relative_path"
          }
        },
        "commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonempty_string"
          }
        },
        "external_effects": {
          "type": "array",
          "maxItems": 0
        }
      },
      "additionalProperties": false
    },
    "phase4_na_policy": {
      "if": {
        "properties": {
          "options": {
            "properties": {
              "status": {
                "const": "NOT_APPLICABLE"
              }
            },
            "required": [
              "status"
            ]
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "properties": {
              "task_profile": {
                "enum": [
                  "build",
                  "debug",
                  "repair"
                ]
              },
              "options": {
                "properties": {
                  "code": {
                    "const": "single_mechanical_outcome"
                  },
                  "evidence": {
                    "type": "object",
                    "required": [
                      "only_viable_change",
                      "risk_assessment"
                    ],
                    "properties": {
                      "only_viable_change": {
                        "$ref": "#/$defs/nonempty_string"
                      },
                      "risk_assessment": {
                        "$ref": "#/$defs/nonempty_string"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              }
            }
          },
          {
            "properties": {
              "task_profile": {
                "enum": [
                  "build",
                  "debug",
                  "repair",
                  "plan_only"
                ]
              },
              "options": {
                "properties": {
                  "code": {
                    "const": "no_safe_executable_prototype"
                  },
                  "evidence": {
                    "type": "object",
                    "required": [
                      "prototype_risk",
                      "non_mutating_alternative"
                    ],
                    "properties": {
                      "prototype_risk": {
                        "$ref": "#/$defs/nonempty_string"
                      },
                      "non_mutating_alternative": {
                        "$ref": "#/$defs/nonempty_string"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              }
            }
          }
        ]
      }
    },
    "plan_review_packet": {
      "type": "object",
      "required": [
        "schema_version",
        "run_id",
        "task_profile",
        "goal",
        "intake",
        "territory_discovery",
        "unknowns",
        "options",
        "acceptance_criteria",
        "plan",
        "mutation_scope"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "$ref": "#/$defs/nonempty_string"
        },
        "task_profile": {
          "enum": [
            "build",
            "debug",
            "repair",
            "plan_only"
          ]
        },
        "goal": {
          "$ref": "#/$defs/nonempty_string"
        },
        "intake": {
          "$ref": "#/$defs/intake"
        },
        "territory_discovery": {
          "$ref": "#/$defs/territory"
        },
        "unknowns": {
          "$ref": "#/$defs/unknowns"
        },
        "options": {
          "$ref": "#/$defs/options"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/criterion"
          }
        },
        "plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/plan_step"
          }
        },
        "mutation_scope": {
          "$ref": "#/$defs/scope"
        },
        "replan_from": {
          "const": "UNKNOWNS_AND_BLINDSPOTS"
        }
      },
      "allOf": [
        {
          "$ref": "#/$defs/phase4_na_policy"
        },
        {
          "if": {
            "properties": {
              "task_profile": {
                "const": "plan_only"
              }
            },
            "required": [
              "task_profile"
            ]
          },
          "then": {
            "properties": {
              "mutation_scope": {
                "properties": {
                  "paths": {
                    "maxItems": 0
                  },
                  "commands": {
                    "maxItems": 0
                  },
                  "external_effects": {
                    "maxItems": 0
                  }
                }
              },
              "plan": {
                "items": {
                  "properties": {
                    "surfaces": {
                      "maxItems": 0
                    }
                  }
                }
              }
            }
          },
          "else": {
            "properties": {
              "mutation_scope": {
                "properties": {
                  "paths": {
                    "minItems": 1
                  }
                }
              },
              "plan": {
                "items": {
                  "properties": {
                    "surfaces": {
                      "minItems": 1
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
