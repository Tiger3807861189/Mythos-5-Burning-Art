{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/terminal-packet.schema.json",
  "title": "Mythos Explicit Non-Success Terminal Packet",
  "type": "object",
  "required": ["schema_version", "run_id", "terminal_state", "current_phase", "reason", "evidence", "resume_condition"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "terminal_state": {"enum": ["BLOCKED", "NEEDS_HUMAN_JUDGMENT"]},
    "current_phase": {"enum": ["INTAKE", "TERRITORY_DISCOVERY", "UNKNOWNS_AND_BLINDSPOTS", "OPTIONS_REFERENCES_OR_PROTOTYPES", "ACCEPTANCE_CRITERIA", "IMPLEMENTATION_PLAN", "INDEPENDENT_PLAN_CRITIQUE", "AWAITING_HUMAN_PLAN_APPROVAL", "IMPLEMENTATION_LOOP", "INDEPENDENT_VERIFICATION", "PLAN_VS_ACTUAL_RECONCILIATION", "EXPLANATION_AND_COMPREHENSION_CHECK"]},
    "reason": {"type": "string", "minLength": 1},
    "evidence": {"type": "object", "minProperties": 1},
    "resume_condition": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}