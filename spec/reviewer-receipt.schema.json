{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/reviewer-receipt.schema.json",
  "title": "Mythos Independent Reviewer Receipts",
  "oneOf": [
    {
      "title": "Plan critic receipt",
      "type": "object",
      "required": [
        "schema_version",
        "packet_hash",
        "verdict",
        "reviewed_sections",
        "blocking_findings",
        "high_findings",
        "context_contamination"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "packet_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "verdict": {
          "const": "PASS"
        },
        "reviewed_sections": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "enum": [
              "task_profile",
              "replan_provenance",
              "original_request",
              "context_manifest",
              "goal",
              "intake",
              "territory_discovery",
              "unknowns",
              "options",
              "acceptance_criteria",
              "plan",
              "mutation_scope"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "task_profile"
              }
            },
            {
              "contains": {
                "const": "replan_provenance"
              }
            },
            {
              "contains": {
                "const": "original_request"
              }
            },
            {
              "contains": {
                "const": "context_manifest"
              }
            },
            {
              "contains": {
                "const": "goal"
              }
            },
            {
              "contains": {
                "const": "intake"
              }
            },
            {
              "contains": {
                "const": "territory_discovery"
              }
            },
            {
              "contains": {
                "const": "unknowns"
              }
            },
            {
              "contains": {
                "const": "options"
              }
            },
            {
              "contains": {
                "const": "acceptance_criteria"
              }
            },
            {
              "contains": {
                "const": "plan"
              }
            },
            {
              "contains": {
                "const": "mutation_scope"
              }
            }
          ]
        },
        "blocking_findings": {
          "type": "array",
          "maxItems": 0
        },
        "high_findings": {
          "type": "array",
          "maxItems": 0
        },
        "context_contamination": {
          "type": "array",
          "maxItems": 0
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Verifier receipt",
      "type": "object",
      "required": [
        "schema_version",
        "packet_hash",
        "verdict",
        "criteria",
        "scope_matches_approval",
        "approval_current",
        "blocking_findings",
        "high_findings",
        "context_contamination"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "packet_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "verdict": {
          "const": "PASS"
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "criterion",
              "result",
              "evidence"
            ],
            "properties": {
              "criterion": {
                "type": "string",
                "minLength": 1
              },
              "result": {
                "const": "PASS"
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "scope_matches_approval": {
          "const": true
        },
        "approval_current": {
          "const": true
        },
        "blocking_findings": {
          "type": "array",
          "maxItems": 0
        },
        "high_findings": {
          "type": "array",
          "maxItems": 0
        },
        "context_contamination": {
          "type": "array",
          "maxItems": 0
        }
      },
      "additionalProperties": false
    }
  ]
}
