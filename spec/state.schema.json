{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schema/state.schema.json",
  "title": "Mythos Runtime State Snapshot",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "project",
    "task_profile",
    "phase",
    "phase_statuses",
    "phase_records",
    "evidence",
    "attempts",
    "repeated_no_gain_failures",
    "must_stop",
    "terminal_state",
    "terminal_reason",
    "terminal_evidence",
    "resume_condition",
    "last_sequence"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "object",
      "required": [
        "is_git",
        "project_root",
        "repository_id",
        "worktree_id"
      ],
      "properties": {
        "is_git": {
          "type": "boolean"
        },
        "project_root": {
          "type": "string",
          "minLength": 1
        },
        "repository_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "worktree_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "task_profile": {
      "enum": [
        "build",
        "debug",
        "repair",
        "plan_only"
      ]
    },
    "phase": {
      "$ref": "#/$defs/phase"
    },
    "phase_statuses": {
      "type": "object",
      "required": [
        "INTAKE",
        "TERRITORY_DISCOVERY",
        "UNKNOWNS_AND_BLINDSPOTS",
        "OPTIONS_REFERENCES_OR_PROTOTYPES",
        "ACCEPTANCE_CRITERIA",
        "IMPLEMENTATION_PLAN",
        "INDEPENDENT_PLAN_CRITIQUE",
        "AWAITING_HUMAN_PLAN_APPROVAL",
        "IMPLEMENTATION_LOOP",
        "INDEPENDENT_VERIFICATION",
        "PLAN_VS_ACTUAL_RECONCILIATION",
        "EXPLANATION_AND_COMPREHENSION_CHECK",
        "DONE"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/phase_status"
      }
    },
    "phase_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "outcome",
          "reason",
          "evidence",
          "not_applicable_code"
        ],
        "properties": {
          "phase": {
            "$ref": "#/$defs/phase"
          },
          "outcome": {
            "enum": [
              "PASS",
              "NOT_APPLICABLE"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence": {
            "type": "object"
          },
          "not_applicable_code": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "object"
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fingerprint",
          "phase",
          "approval_bundle_hash",
          "act_id",
          "tool_name",
          "tool_input_hash",
          "tool_use_id",
          "permission_request_observed",
          "permission_request_count",
          "project_fingerprint_before",
          "authority_valid_at_close",
          "authority_invalid_reasons",
          "scope_valid_at_close",
          "unapproved_paths",
          "step",
          "hypothesis",
          "action",
          "evidence_snapshot",
          "failed",
          "evidence_gain",
          "project_fingerprint"
        ],
        "properties": {
          "fingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "phase": {
            "$ref": "#/$defs/phase"
          },
          "approval_bundle_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "act_id": {
            "type": "string",
            "pattern": "^[a-f0-9]{32}$"
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "tool_input_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "tool_use_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "permission_request_observed": {
            "type": "boolean"
          },
          "permission_request_count": {
            "type": "integer",
            "minimum": 0
          },
          "project_fingerprint_before": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "authority_valid_at_close": {
            "type": "boolean"
          },
          "authority_invalid_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "step": {
            "type": "string",
            "minLength": 1
          },
          "hypothesis": {},
          "action": {},
          "evidence_snapshot": {},
          "failed": {
            "type": "boolean"
          },
          "evidence_gain": {
            "type": "boolean"
          },
          "project_fingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "scope_valid_at_close": {
            "type": "boolean"
          },
          "unapproved_paths": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "repeated_no_gain_failures": {
      "type": "integer",
      "minimum": 0
    },
    "must_stop": {
      "type": "boolean"
    },
    "terminal_state": {
      "enum": [
        null,
        "DONE",
        "BLOCKED",
        "NEEDS_HUMAN_JUDGMENT",
        "AWAITING_HUMAN_INPUT",
        "AWAITING_HUMAN_PLAN_APPROVAL",
        "VERIFICATION_FAILED"
      ]
    },
    "terminal_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "terminal_evidence": {
      "type": [
        "object",
        "null"
      ]
    },
    "resume_condition": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_sequence": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "phase": {
      "enum": [
        "INTAKE",
        "TERRITORY_DISCOVERY",
        "UNKNOWNS_AND_BLINDSPOTS",
        "OPTIONS_REFERENCES_OR_PROTOTYPES",
        "ACCEPTANCE_CRITERIA",
        "IMPLEMENTATION_PLAN",
        "INDEPENDENT_PLAN_CRITIQUE",
        "AWAITING_HUMAN_PLAN_APPROVAL",
        "IMPLEMENTATION_LOOP",
        "INDEPENDENT_VERIFICATION",
        "PLAN_VS_ACTUAL_RECONCILIATION",
        "EXPLANATION_AND_COMPREHENSION_CHECK",
        "DONE"
      ]
    },
    "phase_status": {
      "enum": [
        "PENDING",
        "ACTIVE",
        "PASS",
        "BLOCKED",
        "NOT_APPLICABLE"
      ]
    }
  },
  "additionalProperties": false
}
